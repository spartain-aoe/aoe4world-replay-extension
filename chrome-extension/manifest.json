{
  "manifest_version": 3,
  "name": "AoE4 Replay Launcher",
  "version": "1.1.1",
  "minimum_chrome_version": "111",
  "description": "Watch any AoE4 replay directly from aoe4world.com. One-click download and launch into Age of Empires IV.",
  "permissions": ["storage", "nativeMessaging"],
  "host_permissions": [
    "https://aoe-api.worldsedgelink.com/*",
    "https://rl0aoelivemk2blob.blob.core.windows.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png",
    "default_title": "AoE4 Saved Replays"
  },
  "content_scripts": [
    {
      "matches": ["https://aoe4world.com/players/*/games/*"],
      "js": ["early-hide.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://aoe4world.com/*"],
      "js": ["chart-injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://aoe4world.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/pbgid-map.json"],
      "matches": ["https://aoe4world.com/*"]
    }
  ]
}
